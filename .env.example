# ============================================
# HOSHINO Blog 环境配置
# 复制此文件为 .env 并修改配置
# ============================================

# ---- 数据库选择 ----
# 可选: sqlite (默认) / mysql
DB_TYPE=sqlite

# ---- 数据库连接（当 DB_TYPE=mysql 时必须设置） ----
# 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名?charset=utf8mb4
# DATABASE_URL=mysql+pymysql://hoshino:hoshino_pass@localhost:3306/hoshino_blog?charset=utf8mb4

# ---- 密钥（用于 Session / CSRF） ----
# 生产环境请设置为强随机字符串
SECRET_KEY=hoshino-blog-secret-key

# ---- 调试模式 ----
# 设置为 development 开启调试
FLASK_ENV=production

# ---- 服务端口 ----
PORT=5000
