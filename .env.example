# ─── 数据库连接串（优先级高于下方拆分配置）───
# DATABASE_URL=mysql+pymysql://用户:密码@主机:端口/数据库名?charset=utf8mb4

# ─── 数据库（拆分配置，DATABASE_URL 未设置时自动拼接）───
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# ─── 密钥（用于 Session / CSRF）─────────────
# 生产环境请使用 openssl rand -hex 32 生成强随机字符串
SECRET_KEY=your-secret-key-here

# ─── 默认管理员（首次启动自动创建）─────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
ADMIN_EMAIL=admin@localhost
ADMIN_DISPLAY_NAME=Admin

# ─── 服务器 ─────────────────────────────────
PORT=5000

# ─── 上传 ───────────────────────────────────
MAX_CONTENT_LENGTH=16777216

# ─── 分页（每页文章数）─────────────────────
POSTS_PER_PAGE=6

# ─── 默认主题（dark=深色 / light=浅色）────
DEFAULT_THEME=dark

# ─── Redis 缓存（启用后侧边栏/RSS/仪表盘走缓存）───
# 格式: redis://[:password]@host:port/db
# 留空或删除则禁用缓存
# REDIS_URL=redis://127.0.0.1:6379/0

# ─── SMTP 邮件（B站 UP 主新视频邮件订阅）─────────
# 支持 163 邮箱 / petalmail 等，需开启 SMTP 服务
# 163 邮箱推荐使用 465 + SSL，petalmail 推荐 587 + TLS
# MAIL_SERVER=smtp.163.com
# MAIL_PORT=465
# MAIL_USE_SSL=true
# MAIL_USE_TLS=false
# MAIL_USERNAME=your_email@163.com
# MAIL_PASSWORD=your_smtp_authorization_code
# MAIL_DEFAULT_SENDER=your_email@163.com
# MAIL_TIMEOUT=10

# ─── 服务器名称（后台线程构建绝对 URL 时需要）───
# 格式: host:port，留空则仅请求上下文中可用 url_for(_external=True)
# SERVER_NAME=192.168.3.84:5000
# PREFERRED_URL_SCHEME=http

# ─── Apify API（价格数据爬取）─────────────────
# 从 https://console.apify.com/account#/integrations 获取
# APIFY_TOKEN=your_apify_token_here
# APIFY_ACTOR=apify~amazon-price-scraper
