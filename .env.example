# ─── 数据库连接串（优先级高于下方拆分配置）───
# DATABASE_URL=mysql+pymysql://用户:密码@主机:端口/数据库名?charset=utf8mb4

# ─── 数据库（拆分配置，DATABASE_URL 未设置时自动拼接）───
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# ─── 密钥（用于 Session / CSRF）─────────────
# 生产环境请使用 openssl rand -hex 32 生成强随机字符串
SECRET_KEY=your-secret-key-here

# ─── 默认管理员（首次启动自动创建）─────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@localhost
ADMIN_DISPLAY_NAME=Admin

# ─── 服务器 ─────────────────────────────────
PORT=5000

# ─── 上传 ───────────────────────────────────
MAX_CONTENT_LENGTH=16777216

# ─── 分页（每页文章数）─────────────────────
POSTS_PER_PAGE=6

# ─── 默认主题（dark=深色 / light=浅色）────
DEFAULT_THEME=dark
